\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{kinebot}[2026/03/23 Kinebot Report Template - ABNT]

% =============================================================================
% Packages
% =============================================================================
\RequirePackage[T1]{fontenc}
\RequirePackage[scaled=1.0]{helvet}
\RequirePackage[brazilian]{babel}
\RequirePackage[
  a4paper,
  top=3cm,
  left=3cm,
  right=2cm,
  bottom=5cm
]{geometry}
\RequirePackage{fancyhdr}
\RequirePackage{graphicx}
\RequirePackage{xcolor}
\RequirePackage{hyperref}
\RequirePackage{bookmark}
\RequirePackage{setspace}
\RequirePackage{titlesec}
\RequirePackage{indentfirst}

% =============================================================================
% Font: Arial (Helvetica substitute), 12pt set at \documentclass level
% =============================================================================
\renewcommand{\familydefault}{\sfdefault}

% =============================================================================
% ABNT: 1.5 line spacing, paragraph indent 1.25cm
% =============================================================================
\onehalfspacing
\setlength{\parindent}{1.25cm}

% =============================================================================
% ABNT: Section formatting (bold uppercase for sections, bold for subsections)
% =============================================================================
\titleformat{\section}{\normalfont\bfseries\MakeUppercase}{\thesection}{0.5em}{}
\titleformat{\subsection}{\normalfont\bfseries}{\thesubsection}{0.5em}{}
\titleformat{\subsubsection}{\normalfont\bfseries\itshape}{\thesubsubsection}{0.5em}{}

% =============================================================================
% Colors
% =============================================================================
\definecolor{kinebot-blue}{HTML}{1A3C8F}
\definecolor{kinebot-gray}{HTML}{555555}

% =============================================================================
% Hyperref setup
% =============================================================================
\hypersetup{
  colorlinks=true,
  linkcolor=black,
  urlcolor=kinebot-blue,
  citecolor=kinebot-blue,
  pdfcreator={LaTeX via Kinebot Template}
}

% =============================================================================
% Report metadata commands
% =============================================================================
\newcommand{\@reporttitle}{Titulo do Relatorio}
\newcommand{\@reportsubtitle}{}
\newcommand{\@reportauthor}{Autor}
\newcommand{\@reportdate}{\today}
\newcommand{\@reportref}{}
\newcommand{\@reportcity}{Curitiba}

\newcommand{\reporttitle}[1]{\renewcommand{\@reporttitle}{#1}}
\newcommand{\reportsubtitle}[1]{\renewcommand{\@reportsubtitle}{#1}}
\newcommand{\reportauthor}[1]{\renewcommand{\@reportauthor}{#1}}
\newcommand{\reportdate}[1]{\renewcommand{\@reportdate}{#1}}
\newcommand{\reportref}[1]{\renewcommand{\@reportref}{#1}}
\newcommand{\reportcity}[1]{\renewcommand{\@reportcity}{#1}}

% =============================================================================
% Footer with banner image (only on content pages)
% =============================================================================
\setlength{\headheight}{14.5pt}
\addtolength{\topmargin}{-2.5pt}
\setlength{\footskip}{1.8cm}

% Helper command for the footer content
\newcommand{\@kinebotfooter}{%
  \begin{minipage}{\textwidth}
    \rule{\textwidth}{0.4pt}\vspace{4pt}\par
    \includegraphics[width=0.75\textwidth]{images/footer_banner}%
  \end{minipage}%
}

% Fancy page style (content pages — with footer and page number)
% Default is plain (no footer); switch to fancy after pre-textual elements
\pagestyle{plain}
\fancyhf{}
\renewcommand{\headrulewidth}{0pt}
\renewcommand{\footrulewidth}{0pt}
\fancyhead[R]{\thepage}
\fancyfoot[L]{\@kinebotfooter}

% Plain page style (ToC pages — no footer, no page number)
\fancypagestyle{plain}{%
  \fancyhf{}
  \renewcommand{\headrulewidth}{0pt}
  \renewcommand{\footrulewidth}{0pt}
}

% Empty page style (cover page)
\fancypagestyle{empty}{%
  \fancyhf{}
  \renewcommand{\headrulewidth}{0pt}
  \renewcommand{\footrulewidth}{0pt}
}

% =============================================================================
% Cover page (ABNT style)
% =============================================================================
\newcommand{\makecover}{%
  \begin{titlepage}
    \centering
    \singlespacing

    % Company name / institution
    {\large\bfseries KINEBOT \par}
    \vspace{0.5cm}

    % Author
    {\large \@reportauthor \par}

    \vfill

    % Title
    {\Huge\bfseries \@reporttitle \par}
    \vspace{0.8cm}

    % Subtitle
    \ifx\@reportsubtitle\empty\else
      {\Large \@reportsubtitle \par}
    \fi

    % Reference
    \ifx\@reportref\empty\else
      \vspace{0.3cm}
      {\normalsize \@reportref \par}
    \fi

    \vfill

    % City and date
    {\large \@reportcity \par}
    \vspace{0.3cm}
    {\large \@reportdate \par}
  \end{titlepage}
}
